#!/usr/bin/env bash
set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT"

STAGED_FILES=()
while IFS= read -r -d '' staged_file; do
	STAGED_FILES+=("$staged_file")
done < <(git diff --cached --name-only -z --diff-filter=ACM -- '*.php')

if [ ${#STAGED_FILES[@]} -eq 0 ]; then
	exit 0
fi

if [ ! -f "$REPO_ROOT/.php-cs-fixer.php" ]; then
	echo -e "${RED}Staged PHP files detected, but .php-cs-fixer.php is missing in $REPO_ROOT.${NC}"
	echo -e "${YELLOW}Add a repo-local PHP-CS-Fixer config or remove the staged PHP changes.${NC}"
	exit 1
fi

find_consumer_app_root() {
	local dir="$REPO_ROOT"

	while [ "$dir" != "/" ]; do
		if [ -f "$dir/docker-compose-dev.yml" ] && [ -x "$dir/php-cs-fixer.sh" ]; then
			echo "$dir"
			return 0
		fi

		dir=$(dirname "$dir")
	done

	return 1
}

find_running_consumer_app_container() {
	local app_root="$1"
	local docker_service="${RADAPTOR_DOCKER_PHP_SERVICE:-php}"
	local preferred_container=""
	local fallback_container=""
	local container_name=""
	local config_files=""

	if ! command -v docker >/dev/null 2>&1; then
		return 1
	fi

	while IFS=$'\t' read -r container_name config_files; do
		if [ -z "$container_name" ]; then
			continue
		fi

		if [ -z "$fallback_container" ]; then
			fallback_container="$container_name"
		fi

		if [[ "$config_files" == *"docker-compose.packages-dev.yml"* ]]; then
			preferred_container="$container_name"
			break
		fi
	done < <(
		docker ps \
			--filter "label=com.docker.compose.project.working_dir=$app_root" \
			--filter "label=com.docker.compose.service=$docker_service" \
			--format '{{.Names}}\t{{.Label "com.docker.compose.project.config_files"}}'
	)

	if [ -n "$preferred_container" ]; then
		printf '%s\n' "$preferred_container"
		return 0
	fi

	if [ -n "$fallback_container" ]; then
		printf '%s\n' "$fallback_container"
		return 0
	fi

	return 1
}

run_fixer_in_consumer_app() {
	local app_root="$1"
	local container_name=""
	local repo_relative_path="${REPO_ROOT#"$app_root"}"
	local container_repo_root="/app${repo_relative_path}"

	if ! container_name="$(find_running_consumer_app_container "$app_root")"; then
		return 1
	fi

	docker exec "$container_name" bash -lc \
		"cd '$container_repo_root' && php-cs-fixer fix --config=.php-cs-fixer.php --quiet --path-mode=intersection -- \"\$@\"" \
		bash "${STAGED_FILES[@]}"
}

# Locate a packages-dev workspace container that has this repo bind-mounted at
# /workspace/packages-dev/<path>. Used when this package repo lives under a
# workspace-root packages-dev/ directory rather than nested inside a consumer
# app. Returns a "<container_name>|<container_repo_root>" pair on stdout.
find_packages_dev_runtime() {
	local dir="$REPO_ROOT"

	while [ "$dir" != "/" ]; do
		if [ "$(basename "$dir")" = "packages-dev" ] && [ -d "$dir" ]; then
			local workspace_root
			workspace_root=$(dirname "$dir")
			local repo_relative_to_packages_dev="${REPO_ROOT#"$dir/"}"
			local container_repo_root="/workspace/packages-dev/$repo_relative_to_packages_dev"
			local docker_service="${RADAPTOR_DOCKER_PHP_SERVICE:-php}"
			local preferred_container=""
			local fallback_container=""
			local container_name=""
			local project_working_dir=""
			local config_files=""

			if ! command -v docker >/dev/null 2>&1; then
				return 1
			fi

			while IFS=$'\t' read -r container_name project_working_dir config_files; do
				if [ -z "$container_name" ]; then
					continue
				fi

				if [[ "$config_files" != *"$workspace_root/docker-compose.packages-dev.yml"* ]]; then
					continue
				fi

				if [ -z "$fallback_container" ]; then
					fallback_container="$container_name"
				fi

				if [ "$project_working_dir" = "$workspace_root/radaptor-app" ]; then
					preferred_container="$container_name"
					break
				fi
			done < <(
				docker ps \
					--filter "label=com.docker.compose.service=$docker_service" \
					--format '{{.Names}}\t{{.Label "com.docker.compose.project.working_dir"}}\t{{.Label "com.docker.compose.project.config_files"}}'
			)

			if [ -z "$preferred_container" ] && [ -z "$fallback_container" ]; then
				return 1
			fi

			printf '%s|%s\n' "${preferred_container:-$fallback_container}" "$container_repo_root"
			return 0
		fi

		dir=$(dirname "$dir")
	done

	return 1
}

run_fixer_in_packages_dev_runtime() {
	local runtime="$1"
	local container="${runtime%%|*}"
	local container_repo_root="${runtime#*|}"

	docker exec "$container" bash -lc \
		"cd '$container_repo_root' && php-cs-fixer fix --config=.php-cs-fixer.php --quiet --path-mode=intersection -- \"\$@\"" \
		bash "${STAGED_FILES[@]}"
}

echo -e "${YELLOW}Running PHP-CS-Fixer on staged PHP files...${NC}"

if app_root="$(find_consumer_app_root)"; then
	echo -e "${YELLOW}Using consumer app container at $app_root for PHP-CS-Fixer.${NC}"
	if ! run_fixer_in_consumer_app "$app_root"; then
		echo -e "${RED}Unable to run PHP-CS-Fixer inside the detected consumer app container.${NC}"
		exit 1
	fi
elif runtime_spec="$(find_packages_dev_runtime)"; then
	echo -e "${YELLOW}Using packages-dev workspace container ${runtime_spec%%|*} for PHP-CS-Fixer.${NC}"
	if ! run_fixer_in_packages_dev_runtime "$runtime_spec"; then
		echo -e "${RED}Unable to run PHP-CS-Fixer inside the packages-dev workspace container.${NC}"
		exit 1
	fi
else
	echo -e "${RED}Unable to locate a supported Docker PHP runtime for this repo.${NC}"
	echo -e "${YELLOW}Start the relevant consumer app stack or workspace package-dev stack and retry.${NC}"
	exit 1
fi

git add -- "${STAGED_FILES[@]}"

echo -e "${GREEN}PHP-CS-Fixer completed successfully.${NC}"
